(function injectTestData() {
    const now = new Date();

    const testCases = [
        {
            id: 'A-1',
            carNum: '11가1111',
            carType: '일반',
            // [케이스 1] 5분 전 입차 (회차 - 0원 예상)
            inTime: new Date(now.getTime() - 5 * 60000)
        },
        {
            id: 'A-2',
            carNum: '22나2222',
            carType: '경차',
            // [케이스 2] 2시간 전 입차 (기본+추가요금 - 경차할인 예상)
            inTime: new Date(now.getTime() - 120 * 60000)
        },
        {
            id: 'A-3',
            carNum: '33다3333',
            carType: '일반',
            // [케이스 3] 어제 입차 (24시간 이상 - 일일 최대 요금 예상)
            inTime: new Date(now.getTime() - 24 * 60 * 60000)
        },
        {
            id: 'A-4',
            carNum: '44라4444',
            carType: '장애인',
            // [케이스 4] 2일 전 입차 (다일 주차 - 다일 한도+할인 예상)
            inTime: new Date(now.getTime() - 48 * 60 * 60000)
        }
    ];

    testCases.forEach(test => {
        const card = document.querySelector(`.parking-card[data-id="${test.id}"]`);
        if (card) {
            const displayTime = test.inTime.getHours().toString().padStart(2, '0') + ":" +
                               test.inTime.getMinutes().toString().padStart(2, '0');

            card.dataset.status = 'occupied';
            card.dataset.carNum = test.carNum;
            card.dataset.carType = test.carType;
            card.dataset.inFullTime = test.inTime.toISOString();
            card.dataset.time = displayTime;

            card.classList.replace('available', 'occupied');
            card.querySelector('.box-car').innerText = test.carNum;
            card.querySelector('.box-time').innerText = displayTime;

            console.log(`[테스트] ${test.id} 구역에 데이터 주입 완료 (${test.carType})`);
        }
    });

    alert("테스트 데이터가 주입되었습니다. A-1 ~ A-4 구역을 확인하세요!");
})();
updateParkingCount();